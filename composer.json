{
  "name": "php-lite-admin/laravel-sqlite-admin",
  "description": "SQLite admin panel for Laravel with middleware support.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/view": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "PhpLiteAdmin\\LaravelSqliteAdmin\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "PhpLiteAdmin\\LaravelSqliteAdmin\\SqliteAdminServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
